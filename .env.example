# Copy this to .env and fill in your values

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=poetry_db
DB_USER=poetry_user
DB_PASSWORD=replace-with-a-strong-password

# API Security
SECRET_KEY=replace-with-a-long-random-string

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
